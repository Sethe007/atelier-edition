{
  "name": "atelier-edition",
  "version": "2.0.0",
  "description": "Atelier Édition — Éditeur littéraire professionnel",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:legacy": "terser public/legacy-bundle.js --no-mangle --no-compress --comments false -o dist/legacy-bundle.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "terser": "^5.48.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
